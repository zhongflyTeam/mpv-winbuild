From cd98c9eda7c8e3dec4b08dcdc23ae4d07bd77c4a Mon Sep 17 00:00:00 2001
From: zhongfly <11155705+zhongfly@users.noreply.github.com>
Date: Sun, 9 Mar 2025 19:38:56 +0800
Subject: [PATCH] libarchive: force use openssl

---
 packages/libarchive.cmake | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/packages/libarchive.cmake b/packages/libarchive.cmake
index fa1186e..cbc7796 100644
--- a/packages/libarchive.cmake
+++ b/packages/libarchive.cmake
@@ -12,7 +12,7 @@ ExternalProject_Add(libarchive
     SOURCE_DIR ${SOURCE_LOCATION}
     GIT_CLONE_FLAGS "--filter=tree:0"
     UPDATE_COMMAND ""
-    GIT_RESET de77e6d67166bf667f057bd9515c77bb8dc0f30a
+    PATCH_COMMAND ${EXEC} sed -i [['/^CHECK_CRYPTO/ { /OPENSSL/!d }']] <SOURCE_DIR>/CMakeLists.txt
     CONFIGURE_COMMAND ${EXEC} CONF=1 cmake -H<SOURCE_DIR> -B<BINARY_DIR>
         -G Ninja
         -DCMAKE_BUILD_TYPE=Release
